# Kopieer dit bestand naar .env.local en vul jouw gegevens in

# Supabase — supabase.com → jouw project → Settings → API
REACT_APP_SUPABASE_URL=https://JOUW-PROJECT-ID.supabase.co
REACT_APP_SUPABASE_ANON_KEY=JOUW-ANON-KEY-HIER

# EmailJS — emailjs.com → Account → API Keys
REACT_APP_EMAILJS_SERVICE=service_xxxxxxx
REACT_APP_EMAILJS_TEMPLATE=template_xxxxxxx
REACT_APP_EMAILJS_PUBLIC=JOUW-PUBLIC-KEY
